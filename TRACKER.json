    {
      "id": "D-1",
      "title": "ProductPreview migration strategy",
      "blocks": ["E-W2.1R", "E-W2.2.product"],
      "options": [
        { "id": "A", "label": "Migrate ProductPreview into shared as SharedProductCard", "effort": "~300-500 LoC migration" },
        { "id": "B", "label": "Render-prop escape hatch — shared takes renderProduct?: (product, region) => ReactNode", "effort": "~30 LoC" }
      ],
      "recommended": "B",
      "rationale": "Keeps Wave 2.1-2/3 tight; defer ProductPreview lift to a focused wave once cart actually needs it"
    },
    {
      "id": "D-2",
      "title": "Storefront Swiper CSS import strategy",
      "blocks": ["E-W2.2.swiper", "E-W2.2.product-image-gallery"],
      "options": [
        { "id": "A", "label": "Per-component side-effect import" },
        { "id": "B", "label": "Global _app.tsx CSS pre-import" },
        { "id": "C", "label": "CSS-in-JS via stylesheet tag" }
      ],
      "recommended": "B",
      "rationale": "Single line in _app.tsx; per-component imports redundant"
    },
    {
      "id": "D-3",
      "title": "CartContext contract",
      "blocks": ["E-W3"],
      "options": [
        { "id": "A", "label": "Define CartProvider in shared (creates dep on storefront SDK bridge)" },
        { "id": "B", "label": "Pass cart state via prop drilling" },
        { "id": "C", "label": "Forward-ref pattern" }
      ],
      "recommended": "A",
      "rationale": "Cart components need shared cart state; explicit provider is the cleanest"
    },
    {
      "id": "D-4",
      "title": "Data-fetching contract for *Client wrappers",
      "blocks": ["E-W2.1R", "E-W2.2", "E-W3", "E-W4"],
      "options": [
        { "id": "A", "label": "Each consumer hardcodes its own fetch paths (current pattern)" },
        { "id": "B", "label": "Shared exposes <DataSource> wrapper that takes a fetcher function as prop" }
      ],
      "recommended": "A",
      "rationale": "Per consumer type; only unify if 5+ consumers need the same shape"
    },
    {
      "id": "D-5",
      "title": "Selected IDs storage standard",
      "blocks": ["E-W2.1R"],
      "options": [
        { "id": "A", "label": "string[] (CategoriesGrid established)" },
        { "id": "B", "label": "comma-separated string (legacy)" }
      ],
      "recommended": "A",
      "rationale": "Standardize on string[] going forward"
    }
